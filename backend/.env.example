GROQ_API_KEY=your_groq_api_key_here

# Optional: avoid daily token limit (TPD) on large models. Defaults use llama-3.3-70b + 8b fallback.
# GROQ_MODEL_PRIMARY=llama-3.3-70b-versatile
# GROQ_MODEL_FALLBACK=llama-3.1-8b-instant
# To use GPT-OSS 120B when quota allows: GROQ_MODEL_PRIMARY=openai/gpt-oss-120b
